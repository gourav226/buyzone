# =========================================================================
# BUY ZONE SMTP configuration
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# Your actual email address (e.g. Gmail)
SMTP_USER=kushwahgourav54@gmail.com

# Your App Password (not your regular email password!)
# For Gmail, go to Google Account Settings -> Security -> 2-Step Verification -> App Passwords
SMTP_PASS=xxxx xxxx xxxx xxxx

# Optional settings (defaults to Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# MongoDB cloud URI (optional, if you want cloud database persistence)
# MONGODB_URI=mongodb+srv://...
